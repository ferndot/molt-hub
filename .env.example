# Recommended for desktop: copy to the OS config path (see README), e.g.
#   macOS: ~/Library/Application Support/molt-hub/.env
#   Linux: ~/.config/molt-hub/.env
# Dev shortcut: `.env` in the repo root is also loaded (after the config-dir file).
# Existing shell / launch environment variables are never overwritten.
#
# MOLTHUB_GITHUB_CLIENT_ID=
# MOLTHUB_GITHUB_CLIENT_SECRET=
# MOLTHUB_JIRA_CLIENT_SECRET=
# JIRA_CLIENT_SECRET=
# GITHUB_CLIENT_SECRET=
# MOLTHUB_JIRA_CLIENT_ID=
# MOLTHUB_JIRA_REDIRECT_URI=
# MOLTHUB_GITHUB_REDIRECT_URI=
# MOLTHUB_LOCAL_API_PORT=
# RUST_LOG=info
