{
  "name": "molt-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite ui --config ui/vite.config.ts",
    "build": "tsc --noEmit --project ui/tsconfig.json && vite build ui --config ui/vite.config.ts",
    "preview": "vite preview ui --config ui/vite.config.ts",
    "test": "vitest run --config ui/vite.config.ts",
    "test:watch": "vitest --config ui/vite.config.ts",
    "e2e": "playwright test --config ui/e2e/playwright.config.ts"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "@solidjs/router": "^0.15.0",
    "@tanstack/solid-virtual": "^3.10.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@zed-industries/claude-agent-acp": "latest",
    "dompurify": "^3.3.3",
    "marked": "^17.0.5",
    "solid-icons": "^1.2.0",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.6.0",
    "@types/dompurify": "^3.0.5",
    "@vitest/runner": "^4.1.1",
    "jsdom": "^29.0.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.1.1"
  }
}
