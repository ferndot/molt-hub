# Optional `.env` for non-OAuth settings. Loaded in order (later files do not override existing env):
#   1. OS config dir, e.g. macOS: ~/Library/Application Support/molt-hub/.env
#      Linux: ~/.config/molt-hub/.env
#   2. First `.env` found walking up from the current working directory (dev convenience).
#
# OAuth app client id/secret: NOT here — use only oauth-clients.json next to this file:
#   macOS: ~/Library/Application Support/molt-hub/oauth-clients.json
#   Linux: ~/.config/molt-hub/oauth-clients.json
#
# MOLTHUB_JIRA_REDIRECT_URI=
# MOLTHUB_GITHUB_REDIRECT_URI=
# MOLTHUB_LOCAL_API_PORT=
# RUST_LOG=info
